{
  "name": "stock-analyser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run tests",
    "test:e2e": "playwright test",
    "setup:https": "node scripts/setup-local-https.mjs",
    "https:proxy": "node scripts/https-proxy.mjs",
    "launcher": "node scripts/on-demand-launcher.mjs",
    "launcher:install": "node scripts/install-launcher-agent.mjs",
    "launcher:uninstall": "node scripts/install-launcher-agent.mjs --uninstall"
  },
  "dependencies": {
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "postcss": "8.5.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
